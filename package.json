{
  "name": "angular-liquid-glass-workspace",
  "version": "0.1.1",
  "description": "Angular workspace for the angular-liquid-glass component library.",
  "license": "MIT",
  "author": "Thiago Pires Alves de Castro",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thiagopac/angular-liquid-glass.git"
  },
  "homepage": "https://github.com/thiagopac/angular-liquid-glass#readme",
  "bugs": {
    "url": "https://github.com/thiagopac/angular-liquid-glass/issues"
  },
  "keywords": [
    "angular",
    "angular-library",
    "glassmorphism",
    "liquid-glass",
    "ui-components"
  ],
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "npm run build:package",
    "build:lib": "ng build angular-liquid-glass",
    "build:package": "npm run build:lib && npm run copy:license",
    "copy:license": "cp LICENSE dist/angular-liquid-glass/LICENSE",
    "pack:lib": "npm pack ./dist/angular-liquid-glass",
    "watch": "ng build --watch --configuration development",
    "test": "npm run test:lib",
    "test:lib": "ng test angular-liquid-glass --watch=false",
    "lint": "npm run lint:eslint && npm run format:check",
    "lint:eslint": "eslint . --max-warnings=0",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "release:check": "npm run lint && npm run test && npm run build"
  },
  "private": true,
  "packageManager": "npm@11.6.0",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@angular/build": "^21.2.2",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.2.0",
    "eslint": "^9.39.1",
    "globals": "^16.4.0",
    "jsdom": "^28.0.0",
    "ng-packagr": "^21.2.0",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.46.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
